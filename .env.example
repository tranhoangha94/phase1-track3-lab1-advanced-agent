# Set to 1 to use deterministic mock runtime (no LLM calls)
USE_MOCK=0

# OpenAI-compatible endpoint (Ollama, vLLM, OpenAI, etc.)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2:1.5b

# OpenAI example:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_INPUT_COST_PER_1M=0.15
# LLM_OUTPUT_COST_PER_1M=0.60

# Projection target for cost table in Report.md
REPORT_PROJECTED_QUESTIONS=100
